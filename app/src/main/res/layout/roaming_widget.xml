<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Помощник роуминга"
        android:textColor="#172033"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Быстрый выбор действий"
        android:textColor="#5F6B7A"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_mode_4g3g"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/widget_button_primary"
            android:gravity="center"
            android:text="4G + 3G"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_sms"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/widget_button_secondary"
            android:gravity="center"
            android:text="SMS"
            android:textColor="#172033"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Оператор"
        android:textColor="#5F6B7A"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_operator_mts"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:background="@drawable/widget_button_secondary"
            android:gravity="center"
            android:text="МТС"
            android:textColor="#172033"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_operator_beeline"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:background="@drawable/widget_button_secondary"
            android:gravity="center"
            android:text="Билайн"
            android:textColor="#172033"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_operator_megafon"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:background="@drawable/widget_button_secondary"
            android:gravity="center"
            android:text="МегаФон"
            android:textColor="#172033"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_operator_t2"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:background="@drawable/widget_button_secondary"
            android:gravity="center"
            android:text="T2"
            android:textColor="#172033"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
